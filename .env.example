# Copy to .env.local for Next.js. For Prisma CLI, also set DATABASE_URL below or in prisma/.env
# (Prisma loads project .env and prisma/.env — it does NOT read .env.local.)

# Core
NODE_ENV=development
SKIP_ENV_VALIDATION=1

# Database — required at runtime for NextAuth + API (duplicate in .env.local if you use that for Next)
# Prisma: create a root `.env` with this line, OR edit prisma/.env (repo default = local Docker Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth — https://next-auth.js.org/configuration/options
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# API client (Courses, resume helpers) — defaults to same-origin /api in Next.js
# NEXT_PUBLIC_USE_MOCK_API=true   # only enable for offline UI demos
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
DEV_CREDENTIALS_ENABLED=true

# Demo / admin credentials (after `npm run db:seed`):
#   User:  alice@elevatex.demo  / elevatex-demo
#   Admin: admin@elevatex.ai    / elevatex-demo  (SUPER_ADMIN → /admin/login)
#   Admin: admin@elevatex.demo  / elevatex-demo  (SUPER_ADMIN → /admin/login)
#
# Create admin when none exists (production):
#   ADMIN_PASSWORD='strong-secret' npm run db:seed-admin
# Default seed-admin email: admin@elevatex.ai

# Gemini
GEMINI_API_KEY=

# Inngest — https://www.inngest.com/docs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Dev default: parse resumes inline when Inngest worker is not running. Set false to force Inngest only.
RESUME_PARSE_INLINE=

# Upstash Redis (cache + edge rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Job APIs (optional — mock + Remotive work without keys)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=

# UploadThing v7 — use the dashboard "Token" value, or legacy sk_ secret + app id:
# UPLOADTHING_TOKEN=<base64 from dashboard (recommended)>
# — or —
# UPLOADTHING_SECRET=sk_live_...
# UPLOADTHING_APP_ID=...
# Optional when synthesizing from secret+appId: UPLOADTHING_REGIONS=sea1,fra1
UPLOADTHING_TOKEN=
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
UPLOADTHING_REGIONS=

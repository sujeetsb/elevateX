{
  "name": "elevatex",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "SKIP_ENV_VALIDATION=1 dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma generate && next build && node scripts/copy-pdf-worker.mjs",
    "start": "next start",
    "lint": "next lint",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "postinstall": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma generate",
    "db:generate": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma generate",
    "db:push": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma db push",
    "db:migrate": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma migrate dev",
    "db:seed": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- tsx prisma/seed.ts",
    "db:seed-admin": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- tsx scripts/seed-admin.ts",
    "db:studio": "dotenv -e prisma/.env -e .env --ignore-missing -e .env.local --ignore-missing -- prisma studio",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },

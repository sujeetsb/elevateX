// CareerPilot — production schema (Neon PostgreSQL)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core user ────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  suspendedAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  skills              UserSkill[]
  resumes             Resume[]
  certifications      UserCertification[]
  jobPreferences      JobPreference?
  learningPreferences LearningPreference?
  savedJobs           SavedJob[]
  applications        JobApplication[]
  roadmaps            LearningRoadmap[]
  learningProgress    LearningProgress[]
  courses             Course[]
  courseEnrollments   UserCourse[]
  gamificationEvents  GamificationEvent[]
  aiConversations     AiConversation[]
  aiRecommendations   AiRecommendation[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  analytics           UserAnalytics?
  cachedAiResponses   CachedAiResponse[]
  userInsights        UserInsights?
  courseCertificates  CourseCertificate[]
  optimizedResumes      OptimizedResume[]
  generatedCoverLetters GeneratedCoverLetter[]
  interviewPreps        JobInterviewPrep[]
}

model Profile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  headline             String?
  bio                  String?   @db.Text
  currentRole          String?
  experienceYears      String?
  education            String?   @db.Text
  careerGoal           String?   @db.Text
  targetRole           String?
  preferredIndustry    String?
  preferredIndustries  String[]  @default([])
  themePreference      String?   @default("system")
  salaryExpectation    String?
  salaryGoalCurrency   String?  @default("USD")
  salaryGoalFrequency  String?  @default("Annual")
  currentSalary        String?
  salaryCurrency       String?  @default("USD")
  salaryFrequency      String?  @default("Annual")
  compensationType     String?
  country              String?
  locationPreference   String?
  linkedInUrl          String?
  githubUrl            String?
  portfolioUrl         String?
  onboardingComplete   Boolean   @default(false)
  subscriptionTier     String    @default("FREE")
  profileVersion       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetRole])
  @@index([preferredIndustry])
  @@index([country, salaryCurrency])
  @@index([userId, profileVersion])
}

model UserCertification {
  id            String    @id @default(cuid())
  userId        String
  name          String
  issuer        String
  issueDate     String?
  expiryDate    String?
  credentialId  String?
  credentialUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  category  String?
  createdAt DateTime @default(now())

  users UserSkill[]
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model UserSkill {
  id           String           @id @default(cuid())
  userId       String
  skillId      String
  proficiency  SkillProficiency @default(INTERMEDIATE)
  yearsMonths  Int?
  source       String?
  verified     Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([skillId])
}

enum ResumeParseStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model Resume {
  id            String             @id @default(cuid())
  userId        String
  title         String             @default("Primary CV")
  fileUrl       String?
  filePublicId  String?
  mimeType      String?
  rawText       String?            @db.Text
  /// SHA-256 of rawText for duplicate detection (per user).
  contentHash   String?
  parseVersion  Int                @default(1)
  parsedJson    Json?
  confidence    Json?
  atsScore      Int?
  parseStatus   ResumeParseStatus  @default(PENDING)
  parseError    String?            @db.Text
  lastParsedAt  DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@index([userId, deletedAt, updatedAt])
  @@index([parseStatus])
  @@index([userId, contentHash])
}

model JobPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  remoteOnly      Boolean  @default(false)
  locations       String[] @default([])
  salaryMin       Int?
  salaryMax       Int?
  employmentTypes String[] @default([])
  companySize     String?
  keywords        String[] @default([])
  excludeKeywords String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  pace             String?
  weeklyHours      Int?
  preferredFormats String[] @default([])
  topics           String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Jobs (normalized + user data) ───────────────────────────────

enum JobSource {
  ADZUNA
  REMOTIVE
  GREENHOUSE
  LEVER
  USAJOBS
  JSEARCH
  ARBEITNOW
  MOCK
  MANUAL
}

model Job {
  id          String    @id @default(cuid())
  source      JobSource
  externalId  String
  title       String
  company     String
  location    String?
  description String?   @db.Text
  url         String
  salaryMin   Int?
  salaryMax   Int?
  currency    String?   @default("USD")
  postedAt    DateTime?
  metadata    Json?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  savedBy      SavedJob[]
  applications JobApplication[]
  optimizedResumes OptimizedResume[]
  generatedCoverLetters GeneratedCoverLetter[]
  interviewPreps   JobInterviewPrep[]

  @@unique([source, externalId])
  @@index([company])
  @@index([title])
  @@index([deletedAt])
  @@index([deletedAt, updatedAt])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
}

enum ApplicationStatus {
  DRAFT
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id          String              @id @default(cuid())
  userId      String
  jobId       String
  status      ApplicationStatus   @default(DRAFT)
  appliedAt   DateTime?
  notes       String?             @db.Text
  matchScore  Int?
  aiSummary   String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([jobId])
}

// ─── Learning ───────────────────────────────────────────────────

enum RoadmapStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model LearningRoadmap {
  id          String         @id @default(cuid())
  userId      String
  title       String
  summary     String?        @db.Text
  jsonPlan    Json?
  status      RoadmapStatus  @default(ACTIVE)
  targetRole  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress LearningProgress[]

  @@index([userId, status])
}

model LearningProgress {
  id          String    @id @default(cuid())
  userId      String
  roadmapId   String?
  resourceId  String
  resourceUrl String
  title       String
  provider    String
  completed   Boolean   @default(false)
  progressPct Int       @default(0)
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap LearningRoadmap? @relation(fields: [roadmapId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roadmapId])
  @@index([userId, roadmapId])
}

// ─── AI Courses ───────────────────────────────────────────────────

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  PROJECT
}

enum UserCourseStatus {
  ACTIVE
  COMPLETED
  PAUSED
  SAVED
}

model Course {
  id               String           @id @default(cuid())
  userId           String?
  title            String
  description      String           @db.Text
  category         String           @default("AI Generated")
  difficulty       CourseDifficulty @default(INTERMEDIATE)
  estimatedDays    Int              @default(30)
  totalXp          Int              @default(1500)
  thumbnail        String           @default("🤖")
  tags             String[]         @default([])
  aiGenerated      Boolean          @default(true)
  status           CourseStatus     @default(ACTIVE)
  expectedOutcomes String[]         @default([])
  timeline         Json?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  modules     CourseModule[]
  enrollments UserCourse[]
  certificates CourseCertificate[]

  @@index([userId, status])
  @@index([status, deletedAt])
  @@index([deletedAt])
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  orderIndex  Int      @default(0)
  title       String
  description String   @db.Text
  xpReward    Int      @default(200)
  locked      Boolean  @default(false)
  subtopics   String[] @default([])
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, orderIndex])
  @@index([courseId])
}

model Lesson {
  id           String     @id @default(cuid())
  moduleId     String
  orderIndex   Int        @default(0)
  title        String
  content      String?    @db.Text
  duration     String     @default("15 min")
  type         LessonType @default(READING)
  xpReward     Int        @default(80)
  assignment   String?    @db.Text
  projectBrief String?    @db.Text
  createdAt    DateTime   @default(now())

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz     Quiz?
  progress LessonProgress[]

  @@index([moduleId, orderIndex])
  @@index([moduleId])
}

model Quiz {
  id           String @id @default(cuid())
  lessonId     String @unique
  questions    Json
  passingScore Int    @default(70)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model UserCourse {
  id               String           @id @default(cuid())
  userId           String
  courseId         String
  status           UserCourseStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now())
  completedAt      DateTime?
  progressPct      Int              @default(0)
  xpEarned         Int              @default(0)
  timeSpentMinutes Int              @default(0)
  saved            Boolean          @default(false)
  lastAccessedAt   DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([userId, status])
}

model LessonProgress {
  id               String    @id @default(cuid())
  userCourseId     String
  lessonId         String
  completed        Boolean   @default(false)
  completedAt      DateTime?
  quizScore        Int?
  timeSpentMinutes Int       @default(0)

  userCourse UserCourse @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userCourseId, lessonId])
}

model GamificationEvent {
  id         String   @id @default(cuid())
  userId     String
  actionKey  String
  actionType String
  xpAmount   Int
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actionKey])
  @@index([userId, createdAt])
}

// ─── AI ─────────────────────────────────────────────────────────

enum AiConversationType {
  MENTOR
  RESUME
  INTERVIEW
  CAREER
  GENERAL
}

model AiConversation {
  id        String               @id @default(cuid())
  userId    String
  type      AiConversationType   @default(GENERAL)
  title     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, type])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  promptVersion  String?
  tokenEstimate  Int?
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum RecommendationKind {
  JOB
  LEARNING
  RESUME_ACTION
  SKILL_GAP
  CAREER_STEP
}

model AiRecommendation {
  id          String               @id @default(cuid())
  userId      String
  kind        RecommendationKind
  score       Int?
  payload     Json
  rationale   String?              @db.Text
  promptKey   String?
  promptVer   String?
  dismissed   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, dismissed])
  @@index([expiresAt])
}

model CachedAiResponse {
  id          String   @id @default(cuid())
  userId      String?
  cacheKey    String   @unique
  promptKey   String
  promptVer   String
  model       String
  response    Json
  tokenIn     Int?
  tokenOut    Int?
  hitCount    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Activity & notifications ────────────────────────────────────

enum NotificationChannel {
  IN_APP
  EMAIL
}

model Notification {
  id        String                @id @default(cuid())
  userId    String
  channel   NotificationChannel   @default(IN_APP)
  title     String
  body      String                @db.Text
  read      Boolean               @default(false)
  metadata  Json?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

enum ActivityVerb {
  SIGN_IN
  PROFILE_UPDATE
  RESUME_UPLOAD
  RESUME_PARSE
  JOB_SAVE
  JOB_APPLY
  ROADMAP_GENERATED
  AI_CHAT
  CACHE_INVALIDATE
  COURSE_START
  COURSE_COMPLETE
  LESSON_COMPLETE
  COVER_LETTER
  DAILY_LOGIN
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String?
  verb      ActivityVerb
  subject   String?
  metadata  Json?
  ipHash    String?
  createdAt DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([verb, createdAt])
}

model UserAnalytics {
  id               String   @id @default(cuid())
  userId           String   @unique
  lastActiveAt     DateTime @default(now())
  jobViews         Int      @default(0)
  jobClicks        Int      @default(0)
  learningMinutes  Int      @default(0)
  aiTokensMonth    Int      @default(0)
  snapshot         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Shared profile intelligence (generated once after resume parse) ───

model UserInsights {
  id                 String   @id @default(cuid())
  userId             String   @unique
  resumeId           String?
  sourceHash         String?
  careerGoals        Json?
  targetRoles        Json?
  recommendedCourses Json?
  salaryInsights     Json?
  skillsGap          Json?
  careerPath         Json?
  industry           String?
  profileVersion     Int?
  generatedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceHash])
  @@index([userId, profileVersion])
  @@index([industry])
  @@index([updatedAt])
}

// ─── Course completion certificates ───────────────────────────────

model CourseCertificate {
  id            String   @id @default(cuid())
  userId        String
  courseId      String
  userCourseId  String?
  certificateId String   @unique
  userName      String
  courseTitle   String
  completedAt   DateTime
  xpEarned      Int      @default(0)
  createdAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ─── Job-tailored resume optimizations ──────────────────────────

model OptimizedResume {
  id               String   @id @default(cuid())
  userId           String
  jobId            String
  jobTitle         String
  company          String?
  sourceResumeId   String?
  template         String   @default("professional")
  resumeVersion    Int      @default(1)
  content          Json
  optimizedText    String?  @db.Text
  missingKeywords  Json?
  atsImprovements  Json?
  suggestedChanges Json?
  atsScoreBefore   Int?
  atsScoreAfter    Int?
  pdfUrl           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([userId, jobId])
  @@index([createdAt])
}

model GeneratedCoverLetter {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  content   Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([userId, jobId])
  @@index([createdAt])
}

// ─── Job interview preparation (PRO) ────────────────────────────

model JobInterviewPrep {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  jobTitle  String
  company   String?
  content   Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([userId, jobId])
  @@index([createdAt])
}

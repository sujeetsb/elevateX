{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/inngest/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/v1/onboarding/resume/parse/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "src/app/api/v1/onboarding/resume/parse-text/route.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "src/app/api/v1/resumes/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    }
  }
}
